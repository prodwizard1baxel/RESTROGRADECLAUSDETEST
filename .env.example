# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string (MongoDB Atlas or self-hosted)
DATABASE_URL="mongodb+srv://<user>:<password>@cluster0.mongodb.net/restaurant-ai?retryWrites=true&w=majority"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# Production: your Vercel URL  |  Local: http://localhost:3000
NEXTAUTH_URL="https://your-domain.com"

# ─── Google OAuth (optional — enables Sign in with Google) ────────────────────
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Google Maps (required for competitor analysis) ───────────────────────────
# Enable: Places API, Geocoding API, Maps JavaScript API
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY="your-server-side-maps-key"
# Same key (or a browser-restricted version) exposed to the client
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-client-side-maps-key"

# ─── Anthropic / Claude (required for AI analysis) ────────────────────────────
# Get at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Razorpay (required for payments) ────────────────────────────────────────
# Get at https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="your-razorpay-secret"
# Webhook secret — set in Razorpay Dashboard > Webhooks
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"
# Same key ID exposed to the client (for Razorpay Checkout JS)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_..."

# ─── Resend (required for invoice emails) ────────────────────────────────────
# Get at https://resend.com — verify your sending domain first
RESEND_API_KEY="re_..."
# Must match a verified domain in your Resend account
RESEND_FROM_EMAIL="RestoRank <noreply@yourdomain.com>"

# ─── Twilio (required for phone OTP login) ────────────────────────────────────
# Get at https://console.twilio.com
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1..."

# ─── Admin ────────────────────────────────────────────────────────────────────
# Set to any strong random string — used to access /api/admin/analytics and /api/debug
ADMIN_API_KEY="your-strong-admin-key-here"
